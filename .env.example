# Monetization infra — auth (Clerk), payments (Polar), sync DB (Neon).
# The app runs fully, free, and unauthenticated without any of these set;
# see the VITE_CLERK_PUBLISHABLE_KEY check in main.tsx/App.tsx.

# Clerk — https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Polar — https://polar.sh/dashboard/<org>/settings → API access token,
# and the product you're selling (Products page, copy its ID).
# Create it as a $4/mo recurring product, no trial, no annual tier yet —
# matches the "Sync — $4/mo" copy already in AccountMenu.tsx. If the real
# price ever changes, update that button text too; nothing reads the price
# back from Polar to display it.
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
# Polar → Settings → Webhooks → create one pointed at
# https://modalruns.com/api/webhook/polar, copy the signing secret it gives you.
POLAR_WEBHOOK_SECRET=

# Neon — https://console.neon.tech → your project → Connection string
# (or provision via the Vercel Postgres/Neon integration, which sets this
# automatically). Run db/schema.sql against it once before first use.
DATABASE_URL=

# Your production origin, used to build the post-checkout redirect URL.
APP_ORIGIN=https://modalruns.com
